# Create this Secret with your actual RDS connection string.
# The DSN format: postgres://pgctl:<password>@<rds-endpoint>:5432/pgctl?sslmode=require
#
# Option 1: Create manually
#   kubectl -n pgctl-loadtest create secret generic rds-dsn \
#     --from-literal=dsn='postgres://pgctl:YOUR_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/pgctl?sslmode=require'
#
# Option 2: Apply this file after filling in the base64-encoded DSN
apiVersion: v1
kind: Secret
metadata:
  name: rds-dsn
  namespace: pgctl-loadtest
type: Opaque
data:
  dsn: <base64-encoded-dsn>
