# Copy this file to terraform.tfvars and adjust as needed.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# ec2_key_name is required — create a key pair in the AWS console first.

ec2_key_name = "my-key-pair"

# region = "us-east-1"
# project_name = "pgctl-loadtest"

# --- EC2 ---
# ec2_instance_type = "m5.xlarge"

# --- RDS ---
# rds_instance_class     = "db.r6g.large"
# rds_allocated_storage  = 100          # GB
# rds_iops               = 3000
# rds_storage_throughput = 125          # MiBps (gp3 minimum)
# rds_multi_az           = true
# rds_engine_version     = "16.4"
